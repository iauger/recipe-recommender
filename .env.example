# Copy this file to .env and fill in paths to your Phase 2 artifacts.
# .env is gitignored — never commit real paths or secrets.

# Elasticsearch
ES_HOST=http://localhost:9200
ES_INDEX=recipes
ES_TIMEOUT=30

# Phase 2 model artifacts (absolute paths recommended)
EMBEDDINGS_PATH=data/final_residual_v2_embeddings.pt
MODEL_PATH=data/best_model_residual_v2_all_features_mse.pth
COLUMN_MAPPING_PATH=data/column_mapping.json
RECIPES_PATH=data/PROCESSED_search_recipes.parquet

# Phase 1 gold dataset (offline pipeline use only)
GOLD_REVIEWS_PATH=data/gold_labeled_reviews.parquet

# User data
USER_PROFILES_PATH=data/user_profiles.parquet

# Model / recommender tuning
HIDDEN_DIM=128
N_NEIGHBORS=20
DEFAULT_TOP_K=10
CANDIDATE_POOL_SIZE=100
RECENCY_HALF_LIFE_DAYS=365
MIN_REVIEWS_FOR_CF=5
